{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "my-music",
  "version": "0.1.10",
  "identifier": "com.cms.my-music",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:release",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "my-music",
        "width": 614,
        "height": 708,
        "minWidth": 614,
        "minHeight": 708,
        "decorations": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**/cover-cache/**/*",
            "**/*"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
